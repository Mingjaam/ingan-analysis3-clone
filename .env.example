# Meta Developers에서 만든 Instagram 앱 정보
IG_APP_ID=your_instagram_app_id
IG_APP_SECRET=your_instagram_app_secret

# Meta App 설정의 Valid OAuth Redirect URIs와 정확히 일치해야 합니다.
IG_REDIRECT_URI=http://127.0.0.1:5000/auth/instagram/callback

# 개발 중에는 앱 역할에 등록된 Instagram Professional 계정으로 테스트하세요.
IG_SCOPES=instagram_business_basic,instagram_business_manage_comments,instagram_business_manage_insights

# 선택값
IG_GRAPH_VERSION=v24.0
IG_MEDIA_LIMIT=24
IG_COMMENT_LIMIT=25
IG_ENRICH_MEDIA_LIMIT=12
PORT=5000
